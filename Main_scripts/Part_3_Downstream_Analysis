## 5. Inflammatory Response Module Score

Calculate an inflammatory response score based on HALLMARK gene
signatures.

## 5.1 Load Inflammatory Signature

```{r load_inflammatory_signature}
# Get HALLMARK inflammatory response genes from MSigDB
inflammatory_genes <- msigdbr(
  species = "Homo sapiens",
  category = "H"
) %>%
  filter(gs_name == "HALLMARK_INFLAMMATORY_RESPONSE") %>%
  pull(gene_symbol)

cat(sprintf("Inflammatory signature loaded (%d genes)\n", length(inflammatory_genes)))

# Show a sample of genes
cat("\nSample genes in signature:\n")
print(head(inflammatory_genes, 10))
```

## 5.2 Calculate Module Score

```{r calculate_inflammatory_score}
# Remove any existing module score columns
obj_final@meta.data <- obj_final@meta.data %>%
  select(-any_of(c("Inflammatory_Response", "Inflammatory_Response1")))

# Add module score (standardized expression of signature genes)
obj_final <- AddModuleScore(
  obj_final,
  features = list(inflammatory_genes),
  name = "Inflammatory_Response",
  seed = 42
)

# Rename the score column
colnames(obj_final@meta.data)[
  colnames(obj_final@meta.data) == "Inflammatory_Response1"
] <- "Inflammatory_Response"
```

## 5.3 Statistical Testing of Inflammatory Score

```{r test_inflammatory_score}
cat("Testing inflammatory score differences between diagnostic groups...\n")

# Focus on main immune cell types
immune_celltypes <- c("Monocytes", "Dendritic_cells", "T_CD4_cells", "T_CD8_cells", "NK_cells")

# Prepare data for testing (at sample level, not cell level)
inflammatory_by_sample <- obj_final@meta.data %>%
  filter(final_annotation %in% immune_celltypes) %>%
  group_by(id_tecnico, comparison_group, final_annotation) %>%
  summarise(
    mean_inflammatory = mean(Inflammatory_Response, na.rm = TRUE),
    n = n(),
    .groups = "drop"
  )

# Perform Wilcoxon tests
inflammatory_results <- list()

for (celltype in immune_celltypes) {
  data_celltype <- inflammatory_by_sample %>%
    filter(final_annotation == celltype)
  
  # Pairwise Wilcoxon tests
  test_result <- pairwise.wilcox.test(
    x = data_celltype$mean_inflammatory,
    g = data_celltype$comparison_group,
    p.adjust.method = "BH"
  )
  
  # Convert to data frame
  result_df <- as.data.frame(test_result$p.value) %>%
    rownames_to_column(var = "Group_1") %>%
    pivot_longer(
      cols = -Group_1,
      names_to = "Group_2",
      values_to = "p_value"
    ) %>%
    filter(!is.na(p_value)) %>%
    mutate(
      Cell_Type = celltype,
      p_value = round(p_value, 4),
      Significant = ifelse(p_value < 0.05, "***", "ns")
    ) %>%
    select(Cell_Type, Group_1, Group_2, p_value, Significant)
  
  inflammatory_results[[celltype]] <- result_df
}

# Combine all results
inflammatory_wilcox <- bind_rows(inflammatory_results)

write.xlsx(
  inflammatory_wilcox,
  "Results/Inflammatory_Response_Wilcoxon_Results.xlsx",
  overwrite = TRUE
)
```

